# Path configuration for 4th-MAVIC-T.
# Set PROJECT_ROOT to your project directory, then source this file:
#   export PROJECT_ROOT=/path/to/4th-MAVIC-T
#   source paths.env
#
# Or: source paths.env  (auto-detects project root from this file's location)

# --- PROJECT_ROOT: set to your project root, or leave unset to auto-detect ---
if [[ -n "${BASH_SOURCE[0]:-}" ]]; then
  PROJECT_ROOT="${PROJECT_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
else
  PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"
fi

# --- Derived paths ---
export PROJECT_ROOT
export SUBMISSION_ROOT="${PROJECT_ROOT}/datasets/BiliSakura/MACIV-T-2025-Submissions"
export DATASET_REFINED="${PROJECT_ROOT}/datasets/BiliSakura/MACIV-T-2025-Structure-Refined"
export DATASET_SRC="${PROJECT_ROOT}/datasets/BiliSakura/MAVIC-T-2025"
export CKPT_BASE="${PROJECT_ROOT}/ckpt"
